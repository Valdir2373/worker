# Única configuração de segurança do worker: o token.
# A proxy orquestradora usa este mesmo token (X-Proxy-Token em HTTP/WS, password em SOCKS5)
# e identifica cada worker pela URL (ex.: https://worker.onrender.com).
USER_PROXY_TOKEN=your-secret-token-here

# Em deploy (Docker/Render): não definir — o entrypoint gera e exporta.
# Local (sem Docker): defina uma senha para o ControlPort do TOR.
TOR_CONTROL_PASSWORD=

# Opcionais (defaults abaixo)
LISTEN_PORT=8080
PROXY_PORT=1080
AUTO_REFRESH_MINUTES=5
